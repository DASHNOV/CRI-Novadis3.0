## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleasePublic/
[xX]64/
[xX]86/
[bB]uild/
[bB]in/
[oO]bj/
[lL]og/
[pP]ackages/

# Visual Studio 2015/2017 cache/options directory
.vs/
*.v2/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUNIT
*.VisualState.xml
TestResult.xml

# Build Results of an ATL Project
[Dd]ebugPS/
[Rr]eleasePS/
dlldata.c

# Benchmark Results
BenchmarkDotNet.Artifacts/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# StyleCop
StyleCop.Cache

# Visual Studio Code
.vscode/

# Rider
.idea/

# Dotnet
.net/

# Environment variables (secrets)
.env

# Generated export files
export-storage/

# Logs applicatifs
src/NovadisApi/logs/
